// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  wallet    Wallet?
  nft       NFT?
  stampLogs StampLog[]
  messages  ChatMessage[]
  votes     Vote[]

  createdProposals Proposal[]       @relation("ProposalCreator")
  loginHistories   LoginHistory[]
  chatReactions    ChatReaction[]
  surveyResponses  SurveyResponse[]

  spotRatings SpotRating[]
}

model Wallet {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  symbolAddress       String   @unique
  symbolPublicKey     String
  encryptedPrivateKey String
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model NFT {
  id         Int     @id @default(autoincrement())
  userId     Int     @unique
  nftId      String  @unique
  level      Int     @default(0)
  title      String?
  stampCount Int     @default(0)

  mosaicId    String?
  issueTxHash String?
  issueAt     DateTime?

  metadataJson      String?
  imageUrl          String?
  metadataTxHash    String?
  metadataUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Spot {
  id           Int     @id @default(autoincrement())
  spotName     String
  floor        String
  description  String?
  qrSecretCode String  @unique

  x     Int    @default(0)
  y     Int    @default(0)
  color String @default("#93C5FD")
  icon  String @default("📍")

  interestTag String?
  ratingDisplayName String?
  
  stampLogs   StampLog[]
  chatRooms   ChatRoom[]
  spotRatings SpotRating[]
}

model StampLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  spotId    Int
  visitedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  spot Spot @relation(fields: [spotId], references: [id])

  @@unique([userId, spotId])
}

model ChatRoom {
  id          Int      @id @default(autoincrement())
  roomName    String
  description String?
  roomType    String   @default("general")
  spotId      Int?
  createdAt   DateTime @default(now())

  spot      Spot?         @relation(fields: [spotId], references: [id])
  messages  ChatMessage[]
  proposals Proposal[]
}

model ChatMessage {
  id          Int      @id @default(autoincrement())
  roomId      Int
  userId      Int
  messageText String
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  replyToMessageId Int?
  replyToMessage   ChatMessage?  @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies          ChatMessage[] @relation("MessageReplies")

  room      ChatRoom       @relation(fields: [roomId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
  reactions ChatReaction[]
}

model Proposal {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  requiredLevel Int
  startAt       DateTime
  endAt         DateTime
  createdAt     DateTime @default(now())

  status        String @default("approved")
  creatorUserId Int?
  creator       User?  @relation("ProposalCreator", fields: [creatorUserId], references: [id])

  chatRoomId Int?
  chatRoom   ChatRoom? @relation(fields: [chatRoomId], references: [id])

  approveTxHash String?
  approvedAt    DateTime?

  options ProposalOption[]
  votes   Vote[]
}

model ProposalOption {
  id         Int    @id @default(autoincrement())
  proposalId Int
  label      String
  sortOrder  Int    @default(0)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  votes    Vote[]

  @@index([proposalId])
}

model Vote {
  id               Int      @id @default(autoincrement())
  proposalId       Int
  proposalOptionId Int
  userId           Int
  votedAt          DateTime @default(now())

  voteTxHash String?
  recordedAt DateTime?

  proposal Proposal       @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  option   ProposalOption @relation(fields: [proposalOptionId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id])

  @@unique([proposalId, userId])
}

model LoginHistory {
  id      Int      @id @default(autoincrement())
  userId  Int
  loginAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatReaction {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  emoji     String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model SurveyResponse {
  id            Int      @id @default(autoincrement())
  userId        Int
  q1            Int
  q2            Int
  q3            Int
  q4            Int
  q5            Int
  q6            Int
  q7            Int
  q8            Int
  q9            Int
  q10           Int
  q11           Int
  q12           Int
  q13           Int
  q14           Int
  q15           Int
  q16           Int
  interestTagsJson String @default("[]")
  goodPoint     String?
  improvePoint  String?
  futureRequest String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model SpotRating {
  id Int @id @default(autoincrement())

  userId  Int
  spotId  Int
  rating  Int
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  spot Spot @relation(fields: [spotId], references: [id])

  @@unique([userId, spotId])
}
